# /opt/discord-panel/.env
# NIKDY necommitovat do gitu!

# Vygeneruj: python3 -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET=ZMEN_ME_NA_NAHODNY_STRING_MIN_32_ZNAKU

# Vygeneruj: python3 -c "import bcrypt; print(bcrypt.hashpw(b'tvojeHeslo', bcrypt.gensalt()).decode())"
HASHED_PASSWORD=$2b$12$EXAMPLE_HASH_ZDE

# URL Cloudflare Workeru (bez lomítka na konci)
CF_WORKER_URL=https://discordbot.TVOJE_SUBDOMENA.workers.dev

# Stejná hodnota jako INTERNAL_TOKEN v Cloudflare Worker proměnných
# Vygeneruj: python3 -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_TOKEN=ZMEN_ME_NA_STEJNOU_HODNOTU_JAKO_V_CF

# Volitelné – platnost session v sekundách (default 3600 = 1h)
SESSION_MAX_AGE=3600
